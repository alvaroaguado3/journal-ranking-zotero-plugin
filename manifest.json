{
  "manifest_version": 2,
  "name": "Journal Impact Ranking",
  "version": "1.0.0",
  "description": "Automatically fetch and append journal impact metrics (Impact Factor, H-Index) from OpenAlex to bibliography entries in Zotero",
  "author": "Alvaro Aguado",
  "homepage_url": "https://github.com/alvaroaguado/journal-ranking-zotero-plugin",
  "applications": {
    "zotero": {
      "id": "journal-ranking@zotero.org",
      "update_url": "https://github.com/alvaroaguado/journal-ranking-zotero-plugin/releases",
      "strict_min_version": "8.0",
      "strict_max_version": "8.*"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
